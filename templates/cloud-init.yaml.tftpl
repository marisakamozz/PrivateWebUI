#cloud-config
package_update: true
bootcmd:
  - mkdir -p ${app_dir}
packages:
  - awscli
  - jq
  - docker.io

write_files:
  - path: ${app_dir}/docker-compose.yml
    owner: root:root
    permissions: "0644"
    encoding: b64
    content: ${docker_compose_b64}
  - path: ${app_dir}/librechat.yaml
    owner: root:root
    permissions: "0644"
    encoding: b64
    content: ${librechat_config_b64}
  - path: ${app_dir}/searxng-settings.yml
    owner: root:root
    permissions: "0644"
    encoding: b64
    content: ${searxng_settings_b64}
  - path: ${app_dir}/start.sh
    owner: root:root
    permissions: "0755"
    content: |
      #!/usr/bin/env bash
      set -euo pipefail

      cd "${app_dir}"

      if ! command -v docker >/dev/null 2>&1; then
        apt-get update
        apt-get install -y docker.io
      fi

      if ! docker compose version >/dev/null 2>&1; then
        apt-get update
        apt-get install -y docker-compose-plugin || apt-get install -y docker-compose-v2
      fi

      systemctl enable --now docker

      if command -v nvidia-ctk >/dev/null 2>&1; then
        nvidia-ctk runtime configure --runtime=docker || true
        systemctl restart docker
      fi

      install -d -m 0755 "${app_dir}/data/hf-cache" "${app_dir}/data/librechat" "${app_dir}/data/uploads" "${app_dir}/data/open-webui"
      chown -R 1000:1000 "${app_dir}/data/librechat" "${app_dir}/data/uploads"

      touch .app-secrets
      chmod 0600 .app-secrets

      ensure_secret() {
        local key="$1"
        local bytes="$2"
        if ! grep -q "^$${key}=" .app-secrets; then
          printf '%s=%s\n' "$${key}" "$(openssl rand -hex "$${bytes}")" >> .app-secrets
        fi
      }

      ensure_secret "VLLM_API_KEY" 24
      ensure_secret "CREDS_KEY" 32
      ensure_secret "CREDS_IV" 16
      ensure_secret "JWT_SECRET" 32
      ensure_secret "JWT_REFRESH_SECRET" 32
      ensure_secret "MEILI_MASTER_KEY" 32
      ensure_secret "SEARXNG_SECRET_KEY" 24
      ensure_secret "FIRECRAWL_API_KEY" 24
      ensure_secret "FIRECRAWL_BULL_AUTH_KEY" 24
      ensure_secret "FIRECRAWL_POSTGRES_PASSWORD" 24

      hf_secret="$(aws secretsmanager get-secret-value --region "${aws_region}" --secret-id "${hf_secret_id}" --query SecretString --output text 2>/dev/null || true)"
      hf_token="$(python3 - "$hf_secret" <<'PY'
      import json
      import sys

      raw = sys.argv[1] if len(sys.argv) > 1 else ""
      token = raw.strip()
      if token.startswith("{"):
          try:
              data = json.loads(token)
              for key in ("HF_TOKEN", "HUGGING_FACE_HUB_TOKEN", "token", "api_token"):
                  if data.get(key):
                      token = str(data[key]).strip()
                      break
          except Exception:
              pass
      print(token)
      PY
      )"

      {
        printf 'AWS_REGION=%s\n' "${aws_region}"
        printf 'HF_SECRET_ID=%s\n' "${hf_secret_id}"
        printf 'HUGGING_FACE_HUB_TOKEN=%s\n' "$hf_token"
        printf 'VLLM_MODEL=%s\n' "${model_id}"
        printf 'VLLM_MAX_MODEL_LEN=%s\n' "${max_model_len}"
        printf 'VLLM_SPECULATIVE_CONFIG=%s\n' '{"method":"mtp","model":"${mtp_assistant_model}","num_speculative_tokens":${num_speculative_tokens}}'
        printf 'VLLM_IMAGE=%s\n' "${vllm_image}"
        printf 'LIBRECHAT_IMAGE=%s\n' "${librechat_image}"
        printf 'OPEN_WEBUI_IMAGE=%s\n' "${open_webui_image}"
        cat .app-secrets
      } > .env
      chmod 0600 .env

      docker compose pull
      docker compose up -d
  - path: /etc/systemd/system/private-web-ui.service
    owner: root:root
    permissions: "0644"
    content: |
      [Unit]
      Description=Private AI Chat Docker Compose stack
      Wants=network-online.target
      After=network-online.target docker.service

      [Service]
      Type=oneshot
      RemainAfterExit=yes
      WorkingDirectory=${app_dir}
      ExecStart=${app_dir}/start.sh
      ExecStop=/usr/bin/docker compose down
      TimeoutStartSec=0

      [Install]
      WantedBy=multi-user.target

runcmd:
  - systemctl daemon-reload
  - systemctl enable private-web-ui.service
  - systemctl start private-web-ui.service
